MCP_HOST=0.0.0.0
MCP_PORT=8000
LOG_LEVEL=INFO

# Policy Chat is secure-by-default. Use dev_header only for local development.
POLICY_CHAT_ENABLED=false
POLICY_CHAT_AUTH_MODE=disabled
# Required when POLICY_CHAT_AUTH_MODE=trusted_proxy; inject only from the private proxy.
POLICY_CHAT_PROXY_SECRET=
POLICY_CHAT_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Use a volume-backed absolute path for internal staging/production.
POLICY_CHAT_STATE_PATH=:memory:
# Per-model server kill switches; only these three identifiers are accepted.
POLICY_CHAT_ENABLED_MODELS=qpm,dfm,io
# Per-process safety backstop; also configure rate limits at the trusted proxy.
POLICY_CHAT_MAX_RUNS_PER_MINUTE=10
