# Production builds expose the route only when explicitly enabled.
VITE_POLICY_CHAT_ENABLED=true
# Prefer a same-origin authenticated reverse proxy in production.
VITE_POLICY_CHAT_API_URL=/api/v1/policy-chat
VITE_POLICY_CHAT_TIMEOUT_MS=15000
# VITE_POLICY_CHAT_DEV_USER is for local dev_header mode only; do not set it in production.